DATABASE_URL=postgresql+asyncpg://moodlepro:moodlepro@localhost:5432/moodlepro
REDIS_URL=redis://localhost:6379/0
INTERNAL_API_TOKEN=change-me-to-a-long-random-secret
STORAGE_DIR=./data
PUBLIC_BASE_URL=http://localhost:8000
GEMINI_API_KEY=

# Groq cloud fallback (used when no cluster GPU worker picks up a job in time).
# Leave GROQ_API_KEY empty to disable the fallback entirely.
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_FALLBACK_GRACE_SECONDS=90
