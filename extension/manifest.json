{
  "manifest_version": 3,
  "name": "MoodlePRO",
  "version": "0.1.0",
  "description": "Live Hebrew/English transcripts, captions, and downloads for BGU Moodle lecture videos.",
  "permissions": ["downloads"],
  "host_permissions": [
    "https://moodle.bgu.ac.il/*",
    "https://151.145.95.59.sslip.io/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://moodle.bgu.ac.il/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.png", "vendor/katex/*"],
      "matches": ["https://moodle.bgu.ac.il/*"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
